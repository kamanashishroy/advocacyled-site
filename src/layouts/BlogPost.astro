---
import Base from './Base.astro';

interface Props {
  title: string;
  description: string;
  date: Date;
  tags: string[];
  type?: string;
  guest?: string;
  slug: string;
  hashtag?: string;
}

const { title, description, date, tags, type = 'post', guest, slug, hashtag } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": description,
  "author": { "@type": "Person", "name": "Kamanashish Roy", "alternateName": "Roy", "url": "https://doubts.page" },
  "publisher": { "@type": "Organization", "name": "advocacyled.com", "url": "https://advocacyled.com" },
  "datePublished": date.toISOString().split('T')[0],
  "dateModified": date.toISOString().split('T')[0],
  "url": `https://advocacyled.com/blog/${slug}`,
  "mainEntityOfPage": `https://advocacyled.com/blog/${slug}`,
  "keywords": tags.join(', '),
};
---

<Base
  title={`${title} - Advocacy-Led Growth`}
  description={description}
  activeNav="blog"
  jsonLd={jsonLd}
>

  <article class="section animate-in">
    <div class="section-label">
      <span class="num">&bull;</span> {type === 'interview' ? 'Interview' : 'Blog'}
    </div>

    <h1 class="t-heading-1" style="margin-bottom: var(--sp-3);">{title}</h1>

    <div class="t-label" style="margin-bottom: var(--sp-8);">
      {formattedDate}
      {guest && <span> &middot; with {guest}</span>}
      {tags.length > 0 && (
        <span> &middot; {tags.join(', ')}</span>
      )}
    </div>

    <div class="blog-content">
      <slot />
    </div>
  </article>

  <div class="section" style="padding-top: 0;">
    <div class="notation-block" style="border-left: 3px solid var(--accent); max-width: 640px;">
      <span class="notation-label">Cite this</span>
      <p style="font-size: 0.9rem; line-height: 1.6; color: var(--muted);">
        Roy, K. "{title}." advocacyled.com, {formattedDate}. <a href={`https://advocacyled.com/blog/${slug}`} style="color: var(--accent);">advocacyled.com/blog/{slug}</a>
      </p>
    </div>

    {hashtag && (
      <div class="discuss-block" style="margin-top: var(--sp-6); max-width: 640px;">
        <div style="display: flex; gap: 1rem; align-items: center; flex-wrap: wrap;">
          <a
            href={`https://x.com/intent/tweet?url=${encodeURIComponent(`https://advocacyled.com/blog/${slug}`)}&hashtags=${hashtag}&text=${encodeURIComponent(``)}`}
            target="_blank"
            rel="noopener noreferrer"
            class="discuss-btn"
          >
            Discuss on X
          </a>
          <a
            href={`https://x.com/search?q=%23${hashtag}`}
            target="_blank"
            rel="noopener noreferrer"
            style="font-family: 'IBM Plex Mono', monospace; font-size: 0.8rem; color: var(--muted); text-decoration: none; border-bottom: 1px solid var(--muted);"
          >
            View #{hashtag} discussion
          </a>
        </div>
      </div>
    )}
  </div>

</Base>

<style is:global>
  .blog-content h2 {
    font-family: 'Playfair Display', serif;
    font-weight: 700;
    font-size: 1.5rem;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    line-height: 1.3;
  }
  .blog-content h3 {
    font-family: 'Playfair Display', serif;
    font-weight: 700;
    font-size: 1.2rem;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    line-height: 1.3;
  }
  .blog-content p {
    font-family: 'DM Sans', sans-serif;
    font-weight: 300;
    font-size: 1.05rem;
    line-height: 1.75;
    margin-bottom: 1.25rem;
    max-width: 640px;
  }
  .blog-content strong {
    font-weight: 500;
  }
  .blog-content em {
    font-style: italic;
  }
  .blog-content blockquote {
    font-family: 'Playfair Display', serif;
    font-style: italic;
    font-size: 1.15rem;
    line-height: 1.6;
    border-left: 3px solid var(--accent);
    padding-left: 1.25rem;
    margin: 2rem 0;
    max-width: 600px;
    color: var(--ink);
  }
  .blog-content ul, .blog-content ol {
    max-width: 640px;
    margin-bottom: 1.25rem;
    padding-left: 1.5rem;
  }
  .blog-content li {
    font-family: 'DM Sans', sans-serif;
    font-weight: 300;
    font-size: 1.05rem;
    line-height: 1.75;
    margin-bottom: 0.5rem;
  }
  .blog-content table {
    width: 100%;
    max-width: 640px;
    border-collapse: collapse;
    margin: 1.5rem 0;
    font-size: 0.95rem;
  }
  .blog-content th, .blog-content td {
    text-align: left;
    padding: 0.6rem 1rem;
    border-bottom: 1px solid rgba(14, 13, 11, 0.1);
  }
  .blog-content th {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--accent);
  }
  .blog-content a {
    color: var(--accent);
    text-decoration: none;
    border-bottom: 1px solid var(--accent);
  }
  .blog-content hr {
    border: none;
    border-top: 1px solid rgba(14, 13, 11, 0.1);
    margin: 2.5rem 0;
    max-width: 640px;
  }
  .discuss-btn {
    display: inline-block;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--paper);
    background: var(--ink);
    padding: 0.6rem 1.25rem;
    text-decoration: none;
    border: none;
    transition: background 0.2s;
  }
  .discuss-btn:hover {
    background: var(--accent);
  }
</style>
