---
import Base from '../layouts/Base.astro';
---

<Base
  title="Share Your Story - Advocacy-Led Growth"
  description="Already running parts of the ALG pattern? Tell us what you're seeing. We're building a practitioner interview series."
  activeNav="connect"
>

  <div class="section animate-in">
    <div class="section-label"><span class="num">&bull;</span> Connect</div>
    <h1 class="t-heading-1" style="margin-bottom: var(--sp-5);">Share your story</h1>

    <p class="section-body" style="max-width: 620px; margin-bottom: var(--sp-8);">
      Already running parts of this pattern? Seeing cohort cascades happen organically?
      We're building a practitioner interview series - real stories from people
      who've been activating ALG before it had a name.
    </p>

    <p class="section-body" style="max-width: 620px; margin-bottom: var(--sp-10); color: var(--muted);">
      This isn't a sales form. It's a conversation starter. Tell us what you're seeing
      and we'll reach out for a 1:1.
    </p>

    <form
      name="alg-connect"
      method="POST"
      data-netlify="true"
      netlify-honeypot="bot-field"
      class="alg-form"
      action="/connect-thanks"
    >
      <input type="hidden" name="form-name" value="alg-connect" />
      <p class="hidden-field" style="display:none;">
        <label>Don't fill this out: <input name="bot-field" /></label>
      </p>

      <div class="form-group">
        <label class="form-label" for="name">Your name</label>
        <input type="text" id="name" name="name" required class="form-input" />
      </div>

      <div class="form-group">
        <label class="form-label" for="email">Email</label>
        <input type="email" id="email" name="email" required class="form-input" />
      </div>

      <div class="form-group">
        <label class="form-label" for="company">Company</label>
        <input type="text" id="company" name="company" required class="form-input" />
      </div>

      <div class="form-group">
        <label class="form-label" for="role">What do you own or influence?</label>
        <select id="role" name="role" required class="form-input">
          <option value="" disabled selected>Select one</option>
          <option value="events">Events and conferences</option>
          <option value="community">Community programs</option>
          <option value="certifications">Certifications and education</option>
          <option value="employer-brand">Employer brand and hiring</option>
          <option value="partnerships">Partner ecosystem</option>
          <option value="marketing-overall">Marketing (overall)</option>
          <option value="executive">Executive / cross-org</option>
          <option value="other">Something else</option>
        </select>
      </div>

      <div class="form-group">
        <label class="form-label" for="pattern">What pattern are you seeing?</label>
        <textarea id="pattern" name="pattern" rows="4" class="form-input" placeholder="What completion moments does your company create? What happens after them today?"></textarea>
      </div>

      <button type="submit" class="toolkit-btn" style="margin-top: var(--sp-4);">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
        Send it
      </button>
    </form>
  </div>

</Base>
