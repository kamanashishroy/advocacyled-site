---
import Base from '../layouts/Base.astro';
---

<Base
  title="Thanks - Advocacy-Led Growth"
  description="We'll be in touch."
  activeNav="connect"
>

  <div class="section animate-in">
    <h1 class="t-heading-1" style="margin-bottom: var(--sp-5);">Got it.</h1>

    <p class="section-body" style="max-width: 620px; margin-bottom: var(--sp-8);">
      Thanks for sharing what you're seeing. Roy will reach out for a conversation.
    </p>

    <p class="section-body" style="max-width: 620px; margin-bottom: var(--sp-8);">
      In the meantime - <a href="/framework" style="color: var(--accent);">read the full framework</a>
      or <a href="/" style="color: var(--accent);">find your ALG surfaces with AI</a>.
    </p>
  </div>

</Base>
