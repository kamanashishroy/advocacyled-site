const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "What Is Advocacy-Led Growth (ALG)?",
  "description": "Advocacy-Led Growth (ALG) is a go-to-market motion where existing participants - employees, community members, event attendees, and partners - become the primary engine of distribution, trust, and pipeline. ALG operates on a 1:1:N architecture.",
  "author": { "@type": "Person", "name": "Kamanashish Roy", "alternateName": "Roy", "url": "https://doubts.page" },
  "publisher": { "@type": "Organization", "name": "advocacyled.com", "url": "https://advocacyled.com" },
  "datePublished": "2024-01-01",
  "dateModified": "2026-03-17",
  "url": "https://advocacyled.com/what-is-advocacy-led-growth",
  "mainEntityOfPage": "https://advocacyled.com/what-is-advocacy-led-growth"
