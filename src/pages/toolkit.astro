---
import Base from '../layouts/Base.astro';

const stages = [
  {
    num: '01',
    label: 'Evaluate',
    desc: 'Determine whether ALG fits your company, understand how it differs from what you already do, and map your existing activation surface.',
    tools: [
      {
        id: '01',
        name: 'Readiness Diagnostic',
        desc: 'Score your company across 4 structural dimensions. Get a readiness profile, recommended entry path, and projected first-campaign performance.',
        time: '~3 min',
        href: '/toolkit/readiness-diagnostic.html',
      },
      {
        id: '02',
        name: 'ALG vs Employee Advocacy',
        desc: 'Side-by-side structural comparison. Understand why ALG produces different outcomes than traditional employee advocacy programs.',
        time: '~2 min',
        href: '/toolkit/alg-vs-ea.html',
      },
      {
        id: '03',
        name: 'Completion Moment Audit',
        desc: 'Catalogue your events, product milestones, community programs, and partner moments. Score intensity, identify gaps, get an activation potential map.',
        time: '~5 min',
        href: '/toolkit/completion-moment-audit.html',
      },
    ],
  },
  {
    num: '02',
    label: 'Build',
    desc: 'Design the value exchange, time your activation within the Belief Window, and plan your first campaign with production timelines and anti-patterns.',
    tools: [
      {
        id: '04',
        name: 'Value Exchange Canvas',
        desc: 'Design what the advocate gains from sharing. Map persona-specific value exchanges across credentials, visibility, economic access, and belonging.',
        time: '~8 min',
        href: '/toolkit/value-exchange-canvas.html',
      },
      {
        id: '05',
        name: 'Belief Window Timing Guide',
        desc: 'Calculate the optimal activation window for each completion moment type. Includes moment-specific timing curves, artifact checklists, and channel sequencing.',
        time: '~6 min',
        href: '/toolkit/belief-window-timing.html',
      },
      {
        id: '06',
        name: 'First Campaign Brief',
        desc: 'Plan your first ALG campaign end-to-end. Smart defaults per moment type, backward production calendar, anti-patterns, approval chain, and good vs bad artifact examples.',
        time: '~10 min',
        href: '/toolkit/first-campaign-brief.html',
      },
    ],
  },
];
---

<Base
  title="ALG Toolkit - Interactive Tools for Advocacy-Led Growth"
  description="Six interactive tools across two stages: Evaluate your ALG readiness and Build your first campaign. Each produces a concrete output you can act on immediately. Free, no signup required."
  activeNav="toolkit"
>

  <div class="section animate-in">
    <div class="section-label"><span class="num">T</span> Toolkit</div>
    <h1 class="section-heading" style="font-size: clamp(1.8rem, 4vw, 2.6rem);">
      Interactive tools for<br>Advocacy-Led Growth
    </h1>
    <p class="section-body" style="margin-bottom: var(--sp-4);">
      Six tools across two stages. Each one produces a concrete output - a score, a canvas, a campaign brief - that you can act on immediately. No signup, no email gate. Start anywhere.
    </p>
    <p class="section-body" style="color: var(--muted); font-size: 0.9rem;">
      Built on the <a href="/framework" style="color: var(--accent);">ALG framework v0.2</a>. Tools open in a new tab for the best interactive experience.
    </p>
  </div>

  {stages.map((stage) => (
    <div class="section">
      <div class="section-label"><span class="num">{stage.num}</span> Stage {stage.num}: {stage.label}</div>
      <p class="section-body" style="margin-bottom: var(--sp-6);">{stage.desc}</p>

      <div class="verticals-grid" style="grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));">
        {stage.tools.map((tool) => {
          const isLive = tool.href !== null;
          if (isLive) {
            return (
              <a href={tool.href} target="_blank" rel="noopener" class="vertical-card">
                <span class="vertical-icon">{tool.id}</span>
                <div class="vertical-name">{tool.name}</div>
                <p class="vertical-desc">{tool.desc}</p>
                <span class="vertical-icon" style="margin-top: var(--sp-3); margin-bottom: 0;">{tool.time}</span>
              </a>
            );
          } else {
            return (
              <div class="vertical-card" style="opacity: 0.45; cursor: default;">
                <span class="vertical-icon">{tool.id}</span>
                <div class="vertical-name">{tool.name}</div>
                <p class="vertical-desc">{tool.desc}</p>
                <span class="vertical-icon" style="margin-top: var(--sp-3); margin-bottom: 0; color: var(--muted);">{tool.time}</span>
              </div>
            );
          }
        })}
      </div>
    </div>
  ))}

  <div class="canon-block" style="margin-top: var(--sp-12);">
    <div class="canon-label">How to use this toolkit</div>
    <p style="font-size: 0.95rem; line-height: 1.7; margin-bottom: var(--sp-4);">
      <strong>If you're exploring ALG for the first time</strong>, start with the Readiness Diagnostic. It takes 3 minutes and tells you whether the structural conditions for ALG exist in your company. Then work through Stage 1 in order.
    </p>
    <p style="font-size: 0.95rem; line-height: 1.7; margin-bottom: var(--sp-4);">
      <strong>If you already know ALG fits</strong>, skip to the Value Exchange Canvas in Stage 2. The canvas is the most important design decision in your first campaign - get the value exchange right and activation follows.
    </p>
    <p style="font-size: 0.95rem; line-height: 1.7;">
      <strong>Each tool produces a concrete output</strong> - a readiness score, a completed canvas, a campaign brief with production timeline. These aren't assessments for assessment's sake. They're working documents you'll use to run your first campaign.
    </p>
  </div>

</Base>
