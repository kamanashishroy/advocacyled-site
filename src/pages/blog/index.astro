---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// Define post groups by slug
const conceptSlugs = [
  'what-is-the-belief-window',
  'what-is-a-cohort-cascade',
  'the-1-1-n-distribution-architecture',
  'what-is-an-aql',
  'completion-moment-taxonomy',
  'the-compound-formula',
];
const compareSlugs = [
  'advocacy-led-growth-vs-employee-advocacy',
  'alg-vs-influencer-marketing',
  'community-led-growths-missing-layer',
];
const strategySlugs = [
  'why-advocacy-led-growth-fails-as-a-campaign',
  'why-advocacy-fails-when-it-feels-like-obligation',
  'the-content-economy-inversion',
  'alg-for-event-marketers',
];

const concepts = conceptSlugs.map(s => allPosts.find(p => p.slug === s)).filter(Boolean);
const comparisons = compareSlugs.map(s => allPosts.find(p => p.slug === s)).filter(Boolean);
const strategy = strategySlugs.map(s => allPosts.find(p => p.slug === s)).filter(Boolean);
const interviews = allPosts.filter(p => p.data.type === 'interview');

// Safety net
const groupedSlugs = [...conceptSlugs, ...compareSlugs, ...strategySlugs];
const ungrouped = allPosts.filter(p => !groupedSlugs.includes(p.slug) && p.data.type !== 'interview');
---

<Base
  title="Blog - Advocacy-Led Growth"
  description="Deep dives into Advocacy Led Growth concepts, practitioner interviews, and the mechanics of 1:1:N distribution. Each post unpacks one idea from the ALG framework."
  activeNav="blog"
>

  <div class="section animate-in">
    <div class="section-label"><span class="num">&bull;</span> Blog</div>
    <h1 class="t-heading-1" style="margin-bottom: var(--sp-5);">Blog</h1>
    <p class="section-body mb-8">
      Each post unpacks one concept from the <a href="/framework" style="color: var(--accent);">ALG framework</a>. Deep dives into the mechanics of Advocacy Led Growth, practitioner interviews, and the patterns behind 1:1:N distribution.
    </p>
  </div>

  <!-- CORE CONCEPTS -->
  <div class="section" style="padding-top: 0; padding-bottom: var(--sp-2);">
    <div class="section-label" style="margin-bottom: var(--sp-4);">
      <span class="num">01</span> Core Concepts
    </div>
    <div class="verticals-grid">
      {concepts.map((post) => (
        <a href={`/blog/${post.slug}`} class="vertical-card">
          <span class="vertical-icon">
            {post.data.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}
          </span>
          <div class="vertical-name">{post.data.title.replace(/ - .*$/, '').replace(/\?.*$/, '?')}</div>
          <p class="vertical-desc">{post.data.description.length > 140 ? post.data.description.substring(0, 140) + '...' : post.data.description}</p>
        </a>
      ))}
    </div>
  </div>

  <!-- COMPARISONS -->
  <div class="section" style="padding-bottom: var(--sp-2);">
    <div class="section-label" style="margin-bottom: var(--sp-4);">
      <span class="num">02</span> Comparisons
    </div>
    <div class="verticals-grid">
      {comparisons.map((post) => (
        <a href={`/blog/${post.slug}`} class="vertical-card">
          <span class="vertical-icon">
            {post.data.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}
          </span>
          <div class="vertical-name">{post.data.title.replace(/ - .*$/, '').replace(/\?.*$/, '?')}</div>
          <p class="vertical-desc">{post.data.description.length > 140 ? post.data.description.substring(0, 140) + '...' : post.data.description}</p>
        </a>
      ))}
    </div>
  </div>

  <!-- STRATEGY -->
  <div class="section" style="padding-bottom: var(--sp-2);">
    <div class="section-label" style="margin-bottom: var(--sp-4);">
      <span class="num">03</span> Strategy
    </div>
    <div class="verticals-grid">
      {strategy.map((post) => (
        <a href={`/blog/${post.slug}`} class="vertical-card">
          <span class="vertical-icon">
            {post.data.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}
          </span>
          <div class="vertical-name">{post.data.title.replace(/ - .*$/, '').replace(/\?.*$/, '?')}</div>
          <p class="vertical-desc">{post.data.description.length > 140 ? post.data.description.substring(0, 140) + '...' : post.data.description}</p>
        </a>
      ))}
    </div>
  </div>

  <!-- INTERVIEWS (if any) -->
  {interviews.length > 0 && (
    <div class="section" style="padding-bottom: var(--sp-2);">
      <div class="section-label" style="margin-bottom: var(--sp-4);">
        <span class="num">04</span> Interviews
      </div>
      <div class="verticals-grid">
        {interviews.map((post) => (
          <a href={`/blog/${post.slug}`} class="vertical-card">
            <span class="vertical-icon">
              interview &middot; {post.data.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}
            </span>
            <div class="vertical-name">{post.data.title.replace(/ - .*$/, '')}</div>
            <p class="vertical-desc">{post.data.description.length > 140 ? post.data.description.substring(0, 140) + '...' : post.data.description}</p>
          </a>
        ))}
      </div>
    </div>
  )}

  <!-- UNGROUPED (safety net) -->
  {ungrouped.length > 0 && (
    <div class="section" style="padding-bottom: var(--sp-2);">
      <div class="verticals-grid">
        {ungrouped.map((post) => (
          <a href={`/blog/${post.slug}`} class="vertical-card">
            <span class="vertical-icon">
              {post.data.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}
            </span>
            <div class="vertical-name">{post.data.title.replace(/ - .*$/, '').replace(/\?.*$/, '?')}</div>
            <p class="vertical-desc">{post.data.description.length > 140 ? post.data.description.substring(0, 140) + '...' : post.data.description}</p>
          </a>
        ))}
      </div>
    </div>
  )}

</Base>
